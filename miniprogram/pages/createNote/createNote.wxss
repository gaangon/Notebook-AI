/* pages/createNote/createNote.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 字段区块 */
.field {
  margin-bottom: 48rpx;
}
.field:last-child {
  margin-bottom: 0;
}

/* 标签 */
.label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 20rpx;
}

/* 标题输入框 —— 加大高度 */
.input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 14rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
  background: #fafafa;
}
.input:focus {
  border-color: #07c160;
  background: #fff;
}

/* 内容输入框 —— 加大高度 */
.textarea {
  width: 100%;
  height: 480rpx;           /* 加大：原来 300rpx → 480rpx */
  border: 2rpx solid #e0e0e0;
  border-radius: 14rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  box-sizing: border-box;
  background: #fafafa;
}
.textarea:focus {
  border-color: #07c160;
  background: #fff;
}

/* 字数提示 */
.char-hint {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 10rpx;
}

/* 按钮行 */
.btn-row {
  display: flex;
  gap: 32rpx;
  margin-top: 56rpx;
}

/* 取消按钮 */
.btn-cancel {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border: 2rpx solid #dcdfe6;
  border-radius: 48rpx;
  font-size: 32rpx;
  color: #666;
  background: #fff;
}

/* 保存按钮 */
.btn-save {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  background: linear-gradient(135deg, #07c160, #06ad56);
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
}
.btn-save.btn-disabled {
  opacity: 0.45;
}

/* 点击反馈 */
.btn-hover {
  opacity: 0.75;
  transform: scale(0.97);
}
