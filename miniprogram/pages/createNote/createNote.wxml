<!--pages/createNote/createNote.wxml-->
<view class="container">
  <view class="card">
    <!-- 标题输入 -->
    <view class="field">
      <text class="label">标题</text>
      <input
        class="input"
        placeholder="请输入笔记标题"
        maxlength="50"
        value="{{title}}"
        bindinput="onTitleInput"
      />
      <text class="char-hint">{{title.length}}/50</text>
    </view>

    <!-- 内容输入 -->
    <view class="field">
      <text class="label">内容（支持 Markdown）</text>
      <textarea
        class="textarea"
        placeholder="请输入内容…"
        maxlength="1000"
        value="{{content}}"
        bindinput="onContentInput"
      />
      <text class="char-hint">{{content.length}}/1000</text>
    </view>
  </view>

  <!-- 按钮 -->
  <view class="btn-row">
    <view class="btn-cancel" bind:tap="onCancel" hover-class="btn-hover">取消</view>
    <view class="btn-save   {{canSubmit ? '' : 'btn-disabled'}}" bind:tap="onSave" hover-class="btn-hover">保存</view>
  </view>
</view>
