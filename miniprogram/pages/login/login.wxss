.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #FFFFFF;
}

.title {
  font-size: 24px;
  font-weight: 600;
  color: #000000;
  margin-bottom: 40px;
}

.login-btn {
  background: #07C160;
  color: #FFFFFF;
  border-radius: 4px;
  width: 200px;
  height: 40px;
  line-height: 40px;
  text-align: center;
  border: none;
  font-size: 16px;
}
