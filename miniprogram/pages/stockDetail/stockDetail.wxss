/* pages/stockDetail/stockDetail.wxss */
.container { min-height: 100vh; background: #f5f7fa; padding-bottom: 60rpx; }

/* 信息卡 */
.info-card {
  background: linear-gradient(135deg, #1aad19, #12c45e);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  color: #fff;
}
.stock-title { display: flex; align-items: baseline; gap: 16rpx; }
.stock-code { font-size: 44rpx; font-weight: 700; font-family: 'Menlo', monospace; }
.stock-name { font-size: 28rpx; opacity: 0.85; }
.stats-row {
  display: flex;
  align-items: center;
  margin-top: 36rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  padding: 24rpx 0;
}
.stat-item { flex: 1; text-align: center; }
.stat-value { display: block; font-size: 36rpx; font-weight: 700; }
.stat-label { display: block; font-size: 22rpx; opacity: 0.8; margin-top: 4rpx; }
.stat-divider { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.3); }

/* 列表 */
.section-title {
  padding: 24rpx 36rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}
.history-list { padding: 0 24rpx; }
.history-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 28rpx 32rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.hist-date { font-size: 28rpx; color: #333; }
.win-rate {
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.win-rate.high { background: #e8f5e9; color: #2e7d32; }
.win-rate.medium { background: #fff3e0; color: #e65100; }
.win-rate.low { background: #ffebee; color: #c62828; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 0; }
.empty-text { font-size: 28rpx; color: #999; }
