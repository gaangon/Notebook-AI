<view class="container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-title">笔记本</view>
    <view class="nav-refresh" bindtap="onRefresh">↻</view>
  </view>
  
  <!-- 笔记输入区 -->
  <textarea class="note-input" value="{{noteContent}}" bindinput="onInput" placeholder="输入笔记..." auto-focus />
  
  <!-- 股票数据展示区（刷新后显示） -->
  <view class="stock-section" wx:if="{{showStock}}">
    <view class="divider"></view>
    <view class="stock-date">{{stockDate}}</view>
    <view class="stock-list">
      <view class="stock-item" wx:for="{{stockList}}" wx:key="*this">
        <text class="stock-code">{{item.code}}</text>
        <view class="stock-bar-bg">
          <view class="stock-bar-fill" style="width: {{item._barWidth}}; background: {{item._barColor}}"></view>
        </view>
        <text class="stock-rate">{{item.rate}}</text>
      </view>
    </view>
  </view>
</view>
