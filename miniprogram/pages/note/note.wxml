<view class="container">
  <!-- 自定义导航栏 -->
  <view class="nav-bar">
    <view class="nav-title">笔记本</view>
    <view class="nav-refresh" bindtap="onRefresh">↻</view>
  </view>
  
  <!-- 笔记输入区 -->
  <textarea class="note-input" value="{{noteContent}}" bindinput="onInput" placeholder="输入笔记..." auto-focus />
  
  <!-- 笔记数据展示区（刷新后显示） -->
  <view class="note-section" wx:if="{{showNotes}}">
    <view class="divider"></view>
    <view class="note-date">{{noteDate}}</view>
    <view class="item-list">
      <view class="item-row" wx:for="{{itemList}}" wx:key="*this">
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
        <view class="score-bar-box">
          <view class="score-bar-bg">
            <view class="score-bar-fill" style="width: {{item._barWidth}}; background: {{item._barColor}}"></view>
          </view>
          <text class="score-text">{{item.score}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
