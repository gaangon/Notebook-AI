.container {
  background: #FFFFFF;
  min-height: 100vh;
}

.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  padding-top: 44px;
}

.nav-title {
  font-size: 16px;
  color: #000000;
  font-weight: 500;
}

.nav-refresh {
  font-size: 18px;
  color: #000000;
  padding: 5px;
}

.note-input {
  width: 100%;
  min-height: 70vh;
  padding: 20px;
  font-size: 16px;
  line-height: 1.8;
  border: none;
  background: transparent;
  box-sizing: border-box;
}

.divider {
  height: 1px;
  background: #EEEEEE;
  margin: 20px;
}

.stock-date {
  font-size: 14px;
  color: #999999;
  text-align: right;
  padding: 0 20px;
  margin-bottom: 10px;
}

.stock-list {
  padding: 0 20px;
}

.stock-item {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}

.stock-code {
  width: 80px;
  font-size: 14px;
  color: #000000;
}

.stock-bar-bg {
  flex: 1;
  height: 10px;
  background: #EEEEEE;
  border-radius: 5px;
  overflow: hidden;
  margin: 0 10px;
}

.stock-bar-fill {
  height: 100%;
  border-radius: 5px;
}

.stock-rate {
  width: 50px;
  font-size: 12px;
  color: #999999;
  text-align: right;
}
