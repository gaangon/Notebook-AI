.container {
  background: #FFFFFF;
  min-height: 100vh;
}

.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  padding-top: 44px;
}

.nav-title {
  font-size: 16px;
  color: #000000;
  font-weight: 500;
}

.nav-refresh {
  font-size: 18px;
  color: #000000;
  padding: 5px;
}

.note-input {
  width: 100%;
  min-height: 70vh;
  padding: 20px;
  font-size: 16px;
  line-height: 1.8;
  border: none;
  background: transparent;
  box-sizing: border-box;
}

.divider {
  height: 1px;
  background: #EEEEEE;
  margin: 20px;
}

.note-date {
  font-size: 14px;
  color: #999999;
  text-align: right;
  padding: 0 20px;
  margin-bottom: 10px;
}

.item-list {
  padding: 0 20px;
}

.item-row {
  display: flex;
  align-items: center;
  margin-bottom: 14px;
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 14px;
  color: #000000;
  font-weight: 500;
}

.item-desc {
  font-size: 12px;
  color: #999;
  margin-top: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score-bar-box {
  display: flex;
  align-items: center;
  width: 200rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.score-bar-bg {
  flex: 1;
  height: 10px;
  background: #EEEEEE;
  border-radius: 5px;
  overflow: hidden;
  margin-right: 10px;
}

.score-bar-fill {
  height: 100%;
  border-radius: 5px;
  transition: width 0.3s ease;
}

.score-text {
  font-size: 12px;
  color: #999999;
  width: 50px;
  text-align: right;
}
