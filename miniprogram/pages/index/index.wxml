<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="title-row">
      <text class="title">📓 股票笔记本</text>
      <text wx:if="{{useMock}}" class="mock-badge">模拟数据</text>
    </view>
    <text class="subtitle">每日推荐 · 胜率跟踪</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-box">
    <view class="spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误提示 -->
  <view wx:elif="{{error}}" class="error-box">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bind:tap="fetchStockData">重试</view>
  </view>

  <!-- 空数据 -->
  <view wx:elif="{{stockData.length === 0}}" class="empty-box">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无推荐数据</text>
    <text class="empty-hint">请先将 stocks.json 上传到云存储</text>
  </view>

  <!-- 数据列表 -->
  <view wx:else class="list">
    <view 
      wx:for="{{stockData}}" 
      wx:key="日期"
      class="date-card"
    >
      <!-- 日期头部 -->
      <view 
        class="date-header"
        bind:tap="toggleExpand"
        data-date="{{item.日期}}"
        hover-class="header-hover"
      >
        <view class="date-left">
          <text class="date-text">{{item.日期}}</text>
          <text class="stock-count">{{item.股票.length}} 只股票</text>
        </view>
        <view class="header-right">
          <!-- 当日平均胜率 -->
          <text class="avg-rate {{item._avgClass}}">
            {{item._avgRate}}%
          </text>
          <text class="arrow {{expandedDate === item.日期 ? 'expanded' : ''}}">▶</text>
        </view>
      </view>

      <!-- 股票列表 -->
      <view wx:if="{{expandedDate === item.日期}}" class="stock-list">
        <view 
          wx:for="{{item.股票}}" 
          wx:for-item="stock"
          wx:key="代码"
          class="stock-row"
          hover-class="row-hover"
        >
          <view class="stock-left" bind:tap="goDetail" data-code="{{stock.代码}}" data-name="{{stock.名称 || ''}}" hover-class="cell-hover">
            <text class="stock-code">{{stock.代码}}</text>
            <text class="stock-name" wx:if="{{stock.名称}}">{{stock.名称}}</text>
            <text class="tap-hint">详情 ›</text>
          </view>
          <view class="win-rate {{stock._class}}">
            {{stock.胜率 * 100}}%
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view wx:if="{{stockData.length > 0}}" class="footer">
    <text class="footer-text">下拉刷新 · 共 {{stockData.length}} 天记录</text>
    <text wx:if="{{useMock}}" class="footer-hint">当前为模拟数据，部署云函数后自动切换</text>
  </view>
</view>
