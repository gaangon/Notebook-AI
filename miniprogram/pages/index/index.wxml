<!--pages/index/index.wxml-->
<view class="container">

  <!-- 头部 -->
  <view class="header">
    <text class="title">我的笔记本</text>
    <view class="header-right">
      <view class="refresh-btn" bind:tap="fetchNoteData" hover-class="btn-hover">
        <text class="refresh-icon">↻</text>
        <text>刷新</text>
      </view>
      <view class="add-btn" bind:tap="goCreate" hover-class="btn-hover">
        <text class="add-icon">+</text>
        <text>新建</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-box">
    <view class="spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空数据 -->
  <view wx:elif="{{noteList.length === 0}}" class="empty-box">
    <text class="empty-icon">📝</text>
    <text class="empty-text">暂无笔记</text>
    <text class="empty-hint">点击右上角「新建」添加本地笔记，或点击「刷新」从服务器拉取</text>
  </view>

  <!-- 笔记列表 -->
  <view wx:else class="list">
    <view
      wx:for="{{noteList}}"
      wx:key="id"
      class="note-card"
      bind:tap="goDetail"
      data-index="{{index}}"
      hover-class="card-hover"
    >
      <view class="note-title-row">
        <text class="note-badge" wx:if="{{item._local}}">本地</text>
        <text class="note-title">{{item.标题}}</text>
      </view>
      <text class="note-date">{{item.创建日期}}</text>
    </view>
  </view>

</view>
