/* pages/index/index.wxss */
.container { min-height: 100vh; background: #f5f7fa; padding-bottom: 120rpx; }

/* ===== 头部 ===== */
.header {
  background: linear-gradient(135deg, #1aad19, #12c45e);
  padding: 60rpx 36rpx 44rpx;
  color: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.title { font-size: 40rpx; font-weight: 700; }
.header-right { display: flex; gap: 20rpx; }
.refresh-btn, .add-btn {
  display: flex; align-items: center; gap: 6rpx;
  font-size: 26rpx;
  background: rgba(255,255,255,0.25);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}
.btn-hover { opacity: 0.7; }
.refresh-icon { font-size: 28rpx; }

/* ===== 加载 ===== */
.loading-box { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.spinner {
  width: 56rpx; height: 56rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1aad19;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { margin-top: 20rpx; font-size: 28rpx; color: #999; }

/* ===== 空状态 ===== */
.empty-box { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: #e8f5e9; color: #1aad19;
  font-size: 48rpx; display: flex; align-items: center; justify-content: center;
  margin-bottom: 20rpx;
}
.empty-text { font-size: 30rpx; color: #333; }
.empty-hint { font-size: 24rpx; color: #999; margin-top: 10rpx; text-align: center; padding: 0 60rpx; }

/* ===== 笔记列表 ===== */
.list { padding: 24rpx; }
.note-card {
  background: #fff; border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  display: flex; justify-content: space-between; align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-hover { background: #f9f9f9; }

.note-title-row { flex: 1; min-width: 0; display: flex; align-items: center; gap: 12rpx; }
.note-badge {
  font-size: 20rpx; color: #999;
  background: #f0f0f0; padding: 4rpx 12rpx;
  border-radius: 12rpx; flex-shrink: 0;
}
.note-title {
  font-size: 30rpx; color: #333; font-weight: 500;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.note-date { font-size: 24rpx; color: #bbb; flex-shrink: 0; margin-left: 20rpx; }
