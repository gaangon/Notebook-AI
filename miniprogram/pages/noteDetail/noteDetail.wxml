<!--pages/noteDetail/noteDetail.wxml-->
<view class="container">
  <!-- 笔记信息卡 -->
  <view class="info-card">
    <view class="note-title-row">
      <text class="note-title">{{title}}</text>
      <text wx:if="{{desc}}" class="note-desc">{{desc}}</text>
    </view>
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{totalCount}}</text>
        <text class="stat-label">记录次数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value {{avgScoreClass}}">{{avgScore}}分</text>
        <text class="stat-label">平均评分</text>
      </view>
    </view>
  </view>

  <!-- 历史记录列表 -->
  <view class="section-title">历史记录</view>

  <view wx:if="{{history.length === 0}}" class="empty">
    <text class="empty-text">暂无该笔记的历史记录</text>
  </view>

  <view wx:else class="history-list">
    <view wx:for="{{history}}" wx:key="idx" class="history-row">
      <text class="hist-date">{{item.date}}</text>
      <view class="score-badge {{item.scoreClass}}">{{item.score}}分</view>
    </view>
  </view>
</view>
