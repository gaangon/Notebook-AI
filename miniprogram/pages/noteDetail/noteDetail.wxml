<!--pages/noteDetail/noteDetail.wxml-->
<view class="container">

  <!-- 标题卡 -->
  <view class="title-card">
    <text class="note-title">{{title}}</text>
    <view class="date-row">
      <text class="note-date">{{创建日期}}</text>
      <text wx:if="{{_local}}" class="local-badge">本地笔记</text>
    </view>
  </view>

  <!-- 内容（Markdown 渲染为 HTML） -->
  <view class="content-card">
    <rich-text nodes="{{richContent}}" />
  </view>

</view>
