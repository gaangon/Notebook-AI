<!--pages/noteDetail/noteDetail.wxml-->
<view class="container">

  <!-- 标题区域 -->
  <view class="title-card">
    <text class="note-title">{{title}}</text>
    <view class="date-row" wx:if="{{createDate}}">
      <text class="note-date">{{createDate}}</text>
    </view>
  </view>

  <!-- 正文区域 -->
  <view class="content-card">
    <rich-text nodes="{{contentHtml}}"></rich-text>
  </view>

</view>
