/* pages/noteDetail/noteDetail.wxss */
.container { min-height: 100vh; background: #f5f7fa; }

/* 标题卡 */
.title-card {
  background: linear-gradient(135deg, #1aad19, #12c45e);
  padding: 60rpx 36rpx 44rpx;
  color: #fff;
}
.note-title { display: block; font-size: 40rpx; font-weight: 700; }
.date-row { display: flex; align-items: center; gap: 16rpx; margin-top: 12rpx; }
.note-date { font-size: 26rpx; opacity: 0.85; }
.local-badge {
  font-size: 20rpx;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

/* 内容卡 */
.content-card {
  background: #fff;
  margin: 24rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  min-height: 300rpx;
}
