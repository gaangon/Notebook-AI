/* pages/noteDetail/noteDetail.wxss */
.container { min-height: 100vh; background: #f5f7fa; padding-bottom: 60rpx; }

/* 信息卡 */
.info-card {
  background: linear-gradient(135deg, #1aad19, #12c45e);
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  color: #fff;
}
.note-title-row { display: flex; flex-direction: column; gap: 8rpx; }
.note-title { font-size: 40rpx; font-weight: 700; }
.note-desc { font-size: 26rpx; opacity: 0.85; }
.stats-row {
  display: flex;
  align-items: center;
  margin-top: 36rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 12rpx;
  padding: 24rpx 0;
}
.stat-item { flex: 1; text-align: center; }
.stat-value { display: block; font-size: 36rpx; font-weight: 700; }
.stat-value.high  { color: #c8e6c9; }
.stat-value.medium { color: #ffe0b2; }
.stat-value.low  { color: #ffcdd2; }
.stat-label { display: block; font-size: 22rpx; opacity: 0.8; margin-top: 4rpx; }
.stat-divider { width: 1rpx; height: 60rpx; background: rgba(255,255,255,0.3); }

/* 列表 */
.section-title {
  padding: 24rpx 36rpx 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}
.history-list { padding: 0 24rpx; }
.history-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 28rpx 32rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}
.hist-date { font-size: 28rpx; color: #333; }
.score-badge {
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.score-badge.high  { background: #e8f5e9; color: #2e7d32; }
.score-badge.medium { background: #fff3e0; color: #e65100; }
.score-badge.low  { background: #ffebee; color: #c62828; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 0; }
.empty-text { font-size: 28rpx; color: #999; }
